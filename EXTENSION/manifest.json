{
    "manifest_version": 2,
  
    "name": "Safe-Space",
    "description": "",
    "version": "1.0",
    "icons": {  
        "16": "images/icon.png",
        "48": "images/icon.png",
        "128": "images/icon.png" 
    },
    "background":{
      "scripts":["js/general.js"],
      "persistent": false
    },
    "content_scripts": [{
      "css": [
          "css/style.css"
      ],
      "js": [
          "js/general.js"
      ],
      "matches": ["*://*/*"]
    }],
    "browser_action": {
      "default_icon": "images/icon.png",
      "default_popup": "ViewPassword.html"
    },
    "permissions": [
            "storage",
            "tabs",
            "activeTab"
          ]
  }